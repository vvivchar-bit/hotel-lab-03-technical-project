@startuml
title Діаграма класів програмної системи "Готель"

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F8FBFF
skinparam classBorderColor #1F4E79
skinparam classFontColor #000000
skinparam classAttributeFontColor #000000
skinparam classFontSize 15
skinparam ArrowColor #1F4E79
skinparam ArrowFontColor #000000
skinparam shadowing false
skinparam roundcorner 10

class "СистемаГотелю" as HotelSystem {
  - номери: Номер[]
  - бронювання: Бронювання[]
  - клієнти: Клієнт[]

  + показатиНомери()
  + створитиБронювання()
  + скасуватиБронювання()
  + змінитиСтатусНомера()
}

class "Номер" as Room {
  - ідентифікатор: число
  - тип: рядок
  - ціна: число
  - статус: рядок

  + отриматиІнформацію()
  + змінитиСтатус()
}

class "Бронювання" as Booking {
  - ідентифікатор: число
  - датаЗаїзду: рядок
  - датаВиїзду: рядок
  - статус: рядок

  + підтвердитиБронювання()
  + скасуватиБронювання()
}

class "Клієнт" as Client {
  - ідентифікатор: число
  - ПІБ: рядок
  - телефон: рядок
  - email: рядок

  + переглянутиНомери()
  + забронюватиНомер()
}

class "Адміністратор" as Administrator {
  - ідентифікатор: число
  - логін: рядок
  - пароль: рядок

  + керуватиНомерами()
  + керуватиБронюваннями()
}

class "СервісЗбереження" as StorageService {
  - ключСховища: рядок

  + зберегтиДані()
  + завантажитиДані()
  + видалитиДані()
}

HotelSystem --> Room : керує
HotelSystem --> Booking : обробляє
HotelSystem --> Client : взаємодіє
HotelSystem ..> StorageService : зберігає дані

Booking --> Room : бронює
Booking --> Client : належить

Administrator --> Room : керує
Administrator --> Booking : контролює

@enduml
